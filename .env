# MongoDB Configuration - Choose one option below

# OPTION 1: MongoDB Atlas (Cloud - Recommended)
# Get your connection string from MongoDB Atlas dashboard
# Format: mongodb+srv://... or Standard (non‑SRV). In this environment, use Standard.
MONGODB_URI=mongodb://mankar2045:admd204519@let-shard-00-00.b3jaf.mongodb.net:27017,let-shard-00-01.b3jaf.mongodb.net:27017,let-shard-00-02.b3jaf.mongodb.net:27017/perfume-store?ssl=true&authSource=admin

# OPTION 2: Local MongoDB (requires local installation)
# Install MongoDB locally and start the service
# MONGODB_URI=mongodb://localhost:27017/perfume-store
#
# Optional fast local fallback (used only when MONGODB_URI fails or is unset in development)
MONGO_LOCAL_FALLBACK=true
# Customize local URI if needed
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/perfume-store

# OPTION 3: Disable MongoDB (memory-only mode for testing)
# Uncomment the line below to run without MongoDB
# MONGODB_URI=

# Troubleshooting MongoDB Atlas:
# 1. Check if your cluster is paused in Atlas dashboard
# 2. Verify network access (IP whitelist) - use 0.0.0.0/0 for all IPs
# 3. Confirm username and password are correct
# 4. Make sure database user has read/write permissions
# 5. Test connection with MongoDB Compass first
# 6. If your environment blocks SRV DNS, use Atlas' "Standard connection string (no SRV)"
#    and set it as MONGODB_URI

