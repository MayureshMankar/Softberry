# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/perfume-store
# Or for MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/perfume-store

# Authentication Configuration
JWT_SECRET=your-super-secret-jwt-key-here-min-32-characters
SESSION_SECRET=your-super-secret-session-key-here-min-32-characters

# Server Configuration
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000
ADMIN_SECRET=your-admin-secret-here

# Email Configuration
# Admin Email (where order notifications will be sent)
ADMIN_EMAIL=admin@yourstore.com

# From Email (sender address)
FROM_EMAIL=no-reply@yourstore.com

# SMTP Configuration (uncomment and configure for real email sending)
# For Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-gmail-address@gmail.com
# SMTP_PASS=your-app-password

# For Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-outlook-address@outlook.com
# SMTP_PASS=your-password

# Optional: For production deployments
# MONGODB_URI=mongodb+srv://your-production-uri
# NODE_ENV=production